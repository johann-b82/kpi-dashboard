# --- PostgreSQL (db service) ---
POSTGRES_USER=kpi_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kpi_db

# --- Nginx Proxy Manager (npm service) ---
# NPM has no env vars in v1.11 — first-login bootstrap is manual (D-09):
#   1. Open http://localhost:81 after `docker compose up`
#   2. Log in with the default NPM admin credentials:
#        Email:    admin@example.com
#        Password: changeme
#   3. NPM prompts you to set a real email + password on first login.
#      Change them immediately — these defaults are well-known.
#   4. The new credentials persist in the `npm_data` named volume across
#      container restarts and `docker compose down` / `up` cycles.
