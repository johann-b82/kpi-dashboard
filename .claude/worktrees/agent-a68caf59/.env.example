# --- PostgreSQL (db service) ---
POSTGRES_USER=kpi_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kpi_db

# --- Nginx Proxy Manager (npm service) ---
# NPM has no env vars in v1.11 — first-login bootstrap is manual (D-09):
#   1. Open http://localhost:81 after `docker compose up`
#   2. Log in with the default NPM admin credentials:
#        Email:    admin@example.com
#        Password: changeme
#   3. NPM prompts you to set a real email + password on first login.
#      Change them immediately — these defaults are well-known.
#   4. The new credentials persist in the `npm_data` named volume across
#      container restarts and `docker compose down` / `up` cycles.

# --- Dex OIDC (dex service) ---
# Client secrets for the two OIDC clients Dex hosts (D-13, D-14).
# These same names are read by the api service (Phase 28) and the
# outline service (Phase 29) — single source of truth across the stack.
# Generate real values with:
#   openssl rand -hex 32
# Never commit real secrets — only placeholders in this file.
# The real .env file is gitignored.
DEX_KPI_SECRET=changeme-kpi-light-client-secret
DEX_OUTLINE_SECRET=changeme-outline-client-secret

# --- KPI Dashboard API auth (Phase 28) ---
# SessionMiddleware signing key (D-01). Generate a REAL value with:
#   openssl rand -hex 32
# Never commit the real secret; .env is gitignored.
SESSION_SECRET=changeme-64-hex-chars-generated-by-openssl-rand-hex-32

# Dev-only OIDC bypass (D-13..D-16). Set to `true` ONLY for local UI
# iteration without Dex running. Startup logs a WARNING when active.
DISABLE_AUTH=false

# --- Outline Wiki (outline, outline-db, outline-redis services) ---
# SECRET_KEY and UTILS_SECRET must be TWO INDEPENDENT 32-byte hex values.
# Generate each with:
#   openssl rand -hex 32
# Never commit real secrets — .env is gitignored.
OUTLINE_SECRET_KEY=
OUTLINE_UTILS_SECRET=
# Password for the dedicated outline-db Postgres container (separate from
# POSTGRES_PASSWORD which belongs to KPI Dashboard's `db` service).
OUTLINE_DB_PASSWORD=
# NOTE: DEX_OUTLINE_SECRET is already defined in the Dex block above;
# Outline reuses it (single source of truth per Phase 27 D-14).

# --- KPI Dashboard frontend (Phase 30) ---
# URL the NavBar wiki icon links to. Defaults to https://wiki.internal
# (the Phase 29 Outline edge via NPM). Override for a future real-domain
# deployment without a code edit.
VITE_WIKI_URL=https://wiki.internal
